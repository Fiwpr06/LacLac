{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fiwpr.id.vn/api/v1",
        "EXPO_PUBLIC_FOOD_API_URL": "https://fiwpr.id.vn/api/v1",
        "EXPO_PUBLIC_ACTION_API_URL": "https://fiwpr.id.vn/api/v1"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
